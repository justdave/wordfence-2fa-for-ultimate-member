# This file lists things that should not be in the final generated ZIP file when building the plugin distribution ZIP.
# Ignore Mac Finder droppings
.DS_Store
# Ignore VIM droppings
*.swp
# Other files to not include in final ZIP file
/nondist
/DOCKER_ENV
/docker_tag
/output.log
/.git*
/.distignore
/.markdownlint.json
/.wordpress-org
/.vscode
/vendor
/composer.json
/composer.lock
/phpcs.xml.dist